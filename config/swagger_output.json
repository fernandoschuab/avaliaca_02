          "type": "object",
          "properties": {
            "id": {
              "type": "number",
              "example": 1
            },
            "nome": {
              "type": "string",
              "example": "Admin"
            },
            "usuario": {
              "type": "string",
              "example": "admin"
            },
            "perfil": {
              "type": "string",
              "example": "admin"
            }
          }
        }
      }
